#! /bin/zsh

exit=$?

linux_alert() {
  local icon=utilities-terminal
  local subj="${1:-Alert}"
  (($# > 0)) && shift
  local msg="$*"
  if ((exit != 0)) ; then
    icon=dialog-error
  fi
  notify-send --urgency=low -i "$icon" "$subj" "$msg"
}

macos_alert() {
  local subj="${1:-Alert}"
  (($# > 0)) && shift
  local msg="$*"
  osascript -e "display notification ${(q)msg} with title ${(q)subj}"
}

case "$OSTYPE" in
  darwin*) macos_alert "$@" ;;
  linux-gnu) linux_alert "$@" ;;
esac
